export DS_REGISTRY=portal.dl.kx.com/
export DS_TAG=0.1.0-beta.1
export DS_RT_TAG=1.18.0

# Community Edition license (base64-encoded). Reads from ~/.kx/kc.lic by default.
export KDB_LICENSE_B64=$(base64 -i ~/.kx/kc.lic)
# export KDB_LICENSE_B64="<base64-encoded license string>"

# Commercial k4 license (alternative to KDB_LICENSE_B64)
# export KDB_K4LICENSE_B64=$(base64 -i ~/.kx/k4.lic)

# Community edition memory limits - using Docker configuration (delete to disable):
export DS_SM_MEM_LIMIT=8g
export DS_DA_MEM_LIMIT=6g
export DS_OTHER_MEM_LIMIT=512m

# Community edition memory limits - using cgroup for system-level enforcement:
# export DS_CGROUP_PARENT=kx-db-service.slice

# Override service images to use locally built versions
# export DS_RT_IMAGE=kxi-rt:local
# export DS_SM_IMAGE=kxi-sm-single:local
# export DS_DA_IMAGE=kxi-da-single:local
# export DS_RC_IMAGE=kxi-sg-rc:local
# export DS_AGG_IMAGE=kxi-sg-agg:local
# export DS_GW_IMAGE=kxi-sg-gw:local

# Host port overrides (defaults shown)
# export DS_PORT_HTTP=8080
# export DS_PORT_QIPC=5040
# export DS_PORT_BUS=5002

# KX docker registry
export EMAIL=<your-email>
export BEARER=<your-bearer-token>
